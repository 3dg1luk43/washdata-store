rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isGithubUser() { return isSignedIn() && request.auth.token.firebase.sign_in_provider == 'github.com'; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isBanned() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('banned', false) == true;
    }
    function canContribute() { return isGithubUser() && !isBanned(); }
    function strLen(v, max) { return v is string && v.size() >= 1 && v.size() <= max; }
    // Optional public attribution / manual URL validators (both may be null).
    function optName(v) { return v == null || (v is string && v.size() <= 100); }
    function optUrl(v) { return v == null || (v is string && v.size() <= 500 && v.matches('https?://.*')); }
    // Admin-tunable auto-approve threshold (config/site.confirmThreshold), default 5.
    // config/site is always seeded; fall back to 5 if the doc is ever missing.
    function confirmThreshold() {
      return exists(/databases/$(database)/documents/config/site)
        ? get(/databases/$(database)/documents/config/site).data.get('confirmThreshold', 5)
        : 5;
    }

    // brands
    match /brands/{brandId} {
      // Pending is public (searchable with an "awaiting approval" tag); removed stays hidden.
      allow read: if resource.data.status in ['approved', 'pending'] || isAdmin()
        || (isSignedIn() && resource.data.createdByUid == request.auth.uid);
      allow create: if canContribute()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && strLen(request.resource.data.brand, 40)
        && request.resource.data.brand_lc == request.resource.data.brand.lower()
        && optName(request.resource.data.get('createdByName', null))
        && request.resource.data.createdAt == request.time;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // devices
    match /devices/{deviceId} {
      // Pending is public (searchable with an "awaiting approval" tag); removed stays hidden.
      allow read: if resource.data.status in ['approved', 'pending'] || isAdmin()
        || (isSignedIn() && resource.data.createdByUid == request.auth.uid);
      allow create: if canContribute()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.applianceType in ['washer', 'dryer', 'dishwasher', 'washer_dryer']
        && strLen(request.resource.data.brand, 40) && strLen(request.resource.data.model, 60)
        && request.resource.data.brand_lc == request.resource.data.brand.lower()
        && request.resource.data.model_lc == request.resource.data.model.lower()
        && request.resource.data.favoriteCount == 0
        && request.resource.data.profileCount == 0
        && request.resource.data.confirmCount == 0
        && optUrl(request.resource.data.get('manualUrl', null))
        && optName(request.resource.data.get('createdByName', null))
        && request.resource.data.createdAt == request.time;
      // favoriteCount is a vanity counter: any GitHub user may nudge it by exactly +/-1.
      allow update: if isGithubUser()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favoriteCount'])
        && (request.resource.data.favoriteCount == resource.data.favoriteCount + 1
            || request.resource.data.favoriteCount == resource.data.favoriteCount - 1);
      // Honest confirm-count bump: +1 on confirmCount ONLY when the same batch creates
      // this user's confirmation doc that did not already exist. One per uid, un-gameable.
      allow update: if isGithubUser()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['confirmCount'])
        && request.resource.data.confirmCount == resource.data.confirmCount + 1
        && !exists(/databases/$(database)/documents/devices/$(deviceId)/confirmations/$(request.auth.uid))
        && existsAfter(/databases/$(database)/documents/devices/$(deviceId)/confirmations/$(request.auth.uid));
      // Community auto-promotion: any github user may flip pending -> approved once the
      // honest confirmCount has reached the admin-tunable threshold. status-only change.
      allow update: if isGithubUser()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && resource.data.status == 'pending'
        && request.resource.data.status == 'approved'
        && resource.data.confirmCount >= confirmThreshold();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      // One-way confirmation doc (create-only, own uid); the un-gameable source of truth.
      match /confirmations/{uid} {
        allow read: if true;
        allow create: if canContribute() && request.auth.uid == uid
          && request.resource.data.uid == uid
          && request.resource.data.createdAt == request.time;
        allow update: if false;
        allow delete: if isAdmin();
      }

      // Optional 5-star quality score (information only; never affects approval).
      match /ratings/{uid} {
        allow read: if true;
        allow write: if canContribute() && request.auth.uid == uid
          && request.resource.data.rating in [1, 2, 3, 4, 5];
      }
    }

    // profiles
    match /profiles/{profileId} {
      allow read: if resource.data.status == 'approved' || isAdmin()
        || (isSignedIn() && resource.data.createdByUid == request.auth.uid);
      allow create: if canContribute()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.deviceId is string
        && strLen(request.resource.data.program, 60)
        && request.resource.data.program_lc == request.resource.data.program.lower()
        && request.resource.data.cycleCount == 0
        && request.resource.data.createdAt == request.time;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // cycles (reference golden cycles)
    match /cycles/{cycleId} {
      function isOwner() { return isSignedIn() && resource.data.uploaderUid == request.auth.uid; }
      allow read: if resource.data.status == 'approved' || isOwner() || isAdmin();
      allow create: if canContribute()
        && request.resource.data.uploaderUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.downloads == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.cycleSchemaVersion is number
        && request.resource.data.applianceType in ['washer', 'dryer', 'dishwasher', 'washer_dryer']
        && request.resource.data.deviceId is string
        && request.resource.data.profileId is string
        && request.resource.data.brand_lc is string
        && request.resource.data.program_lc is string
        && request.resource.data.qc is int && request.resource.data.qc >= 1 && request.resource.data.qc <= 3
        && request.resource.data.trace is map
        && request.resource.data.trace.points is list
        && request.resource.data.trace.points.size() <= 3000
        && request.resource.data.stats is map
        && (request.resource.data.uploaderName == null
            || (request.resource.data.uploaderName is string && request.resource.data.uploaderName.size() <= 100))
        && request.resource.data.createdAt == request.time;
      // public download bump: exactly +1 and no other field
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloads'])
        && request.resource.data.downloads == resource.data.downloads + 1;
      // comment count +/-1 by a github user
      allow update: if isGithubUser()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount'])
        && (request.resource.data.commentCount == resource.data.commentCount + 1
            || request.resource.data.commentCount == resource.data.commentCount - 1);
      allow update: if isAdmin();
      allow delete: if (isSignedIn() && isOwner()) || isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if canContribute()
          && request.resource.data.authorUid == request.auth.uid
          && strLen(request.resource.data.text, 1000)
          && (request.resource.data.authorName == null
              || (request.resource.data.authorName is string && request.resource.data.authorName.size() <= 100))
          && request.resource.data.createdAt == request.time
          && (!('parentId' in request.resource.data)
              || request.resource.data.parentId == null
              || request.resource.data.parentId is string);
        allow delete: if (isSignedIn() && resource.data.authorUid == request.auth.uid) || isAdmin();
        allow update: if false;
      }

      match /ratings/{uid} {
        allow read: if true;
        allow write: if canContribute() && request.auth.uid == uid
          && request.resource.data.rating in [1, 2, 3, 4, 5];
      }
    }

    // admins collection - existence == is admin; no client writes; check-own-only read
    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // users collection - self-service cannot touch moderation fields
    match /users/{uid} {
      allow read: if (isSignedIn() && request.auth.uid == uid) || isAdmin();
      allow create: if isGithubUser() && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.get('banned', false) == false;
      allow update: if isAdmin()
        || (isGithubUser() && request.auth.uid == uid
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['displayName', 'photoURL', 'lastSeen', 'favorites'])
            && request.resource.data.banned == resource.data.banned);
      allow delete: if isAdmin();
    }

    // site config (e.g. maintenance flag) - world-readable so clients can gate; admin-only writes
    match /config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} { allow read, write: if false; }
  }
}
